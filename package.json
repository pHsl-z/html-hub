{
  "name": "html-teaching-hub",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "HTML 教案中枢 - 静态化、可托管在 GitHub Pages 的个人 HTML 教学应用展示与运行平台",
  "scripts": {
    "dev": "vite",
    "build:manifest": "node scripts/build-manifest.mjs",
